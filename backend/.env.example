# ──────────────────────────────────────────────────────────
# Environment Variables (copy to .env and customise)
# ──────────────────────────────────────────────────────────

PROJECT_NAME="Multi Camera Person ReID"
VERSION="1.0.0"
DEBUG=false
LOG_LEVEL=INFO

# Comma-separated CORS origins (use * for development)
CORS_ORIGINS=["*"]

# PostgreSQL (Phase 2+)
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/person_reid
